FLASK_APP=app.py
FLASK_ENV=development
SECRET_KEY=replace-with-a-long-random-value
DATABASE_URL=sqlite:///database/ihis.db
UPLOAD_FOLDER=uploads
MAX_CONTENT_LENGTH=16777216
LOG_LEVEL=INFO
WTF_CSRF_ENABLED=true
SESSION_COOKIE_SECURE=false
SESSION_HOURS=8
REMEMBER_DAYS=14
MAX_FAILED_LOGIN_ATTEMPTS=5
ACCOUNT_LOCKOUT_MINUTES=15
MIN_PASSWORD_LENGTH=8
SEED_ADMIN_USERNAME=superadmin
SEED_ADMIN_EMAIL=superadmin@ihis.local
SEED_ADMIN_FIRST_NAME=System
SEED_ADMIN_LAST_NAME=Administrator
# SEED_ADMIN_PASSWORD=set-a-strong-one-time-password
